{
  "name": "lanshare",
  "version": "0.1.0",
  "description": "Share a folder over your LAN via HTTP with a scannable QR code",
  "type": "module",
  "bin": {
    "lanshare": "./dist/cli.js"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "ink": "^5.0.1",
    "qrcode-terminal": "^0.12.0",
    "react": "^18.3.1",
    "serve-handler": "^6.1.5"
  },
  "devDependencies": {
    "@types/node": "^22.5.0",
    "@types/qrcode-terminal": "^0.12.2",
    "@types/react": "^18.3.3",
    "@types/serve-handler": "^6.1.4",
    "tsup": "^8.2.4",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5"
  },
  "engines": {
    "node": ">=18"
  }
}
