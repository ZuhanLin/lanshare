{
  "name": "@linzuhan/lanshare",
  "version": "0.1.0",
  "description": "Share a folder over your LAN via HTTP with a scannable QR code and phone-to-PC upload",
  "type": "module",
  "bin": {
    "lanshare": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm test && npm run build"
  },
  "keywords": [
    "lan",
    "share",
    "http",
    "static-server",
    "qrcode",
    "cli",
    "file-transfer",
    "upload",
    "local-network",
    "phone-to-pc"
  ],
  "author": "linzuhan",
  "license": "MIT",
  "homepage": "https://github.com/ZuhanLin/lanshare#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ZuhanLin/lanshare.git"
  },
  "bugs": {
    "url": "https://github.com/ZuhanLin/lanshare/issues"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "dependencies": {
    "busboy": "^1.6.0",
    "commander": "^12.1.0",
    "ink": "^5.0.1",
    "qrcode-terminal": "^0.12.0",
    "react": "^18.3.1",
    "serve-handler": "^6.1.5"
  },
  "devDependencies": {
    "@types/busboy": "^1.5.4",
    "@types/node": "^22.5.0",
    "@types/qrcode-terminal": "^0.12.2",
    "@types/react": "^18.3.3",
    "@types/serve-handler": "^6.1.4",
    "tsup": "^8.2.4",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5"
  },
  "engines": {
    "node": ">=18"
  }
}
